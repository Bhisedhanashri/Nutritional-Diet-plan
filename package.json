{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter \"@workspace/api-server\" --filter \"@workspace/diet-assistant\" --parallel run dev",
    "preinstall": "node -e \"try{require('fs').unlinkSync('package-lock.json')}catch(e){}; try{require('fs').unlinkSync('yarn.lock')}catch(e){}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
