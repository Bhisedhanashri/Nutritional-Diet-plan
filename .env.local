# Backend API Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Optional - defaults to CSV storage)
# DATABASE_URL=mysql://root:password@localhost:3306/nutriai

# Clerk Authentication Keys - Demo/Development Keys
CLERK_SECRET_KEY=sk_test_demo_development_key
CLERK_PUBLISHABLE_KEY=pk_test_demo_development_key

# Frontend Clerk Configuration
VITE_CLERK_PUBLISHABLE_KEY=pk_test_demo_development_key
VITE_ENV=development
VITE_API_URL=http://localhost:3000

# === AI Integration Setup ===
# For development without real API keys, we use a placeholder
# The application will use fallback/mock responses for AI features

# Dummy OpenAI key (for local development only)
# This allows the app to gracefully handle missing real API keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-test-dummy-key-local-development-only

# Disable Ollama (not installed)
USE_OLLAMA=false

# Enable graceful fallback for AI features
FALLBACK_ON_AI_ERROR=true

# Logging Configuration
LOG_LEVEL=info

